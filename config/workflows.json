[
  {
    "id": "google",
    "name": "🔍 Google 搜索",
    "description": "在 Google 中搜索内容",
    "icon": "🔍",
    "keywords": ["g", "google", "搜索"],
    "priority": 10,
    "action": "open_url",
    "args": { "url": "https://www.google.com/search?q={query}" }
  },
  {
    "id": "github",
    "name": "🐙 GitHub 搜索",
    "description": "在 GitHub 上搜索代码或仓库",
    "icon": "🐙",
    "keywords": ["gh", "github"],
    "priority": 20,
    "action": "open_url",
    "args": { "url": "https://github.com/search?q={query}" }
  },
  {
    "id": "open_github",
    "name": "🌐 打开 GitHub 主页",
    "description": "在浏览器中打开 GitHub",
    "icon": "🌐",
    "priority": 50,
    "action": "open_url",
    "args": { "url": "https://github.com" }
  },
  {
    "id": "run_tests",
    "name": "⚡ 运行测试",
    "description": "运行 AlfredPy 测试套件 (pytest)",
    "icon": "⚡",
    "keywords": ["test", "pytest"],
    "priority": 60,
    "action": "run",
    "args": { "command": ["pytest", "--no-cov", "-q"] }
  },
  {
    "id": "copy_text",
    "name": "📋 复制文本到剪贴板",
    "description": "将搜索框内容复制到剪贴板",
    "icon": "📋",
    "keywords": ["copy", "cp", "复制"],
    "priority": 70,
    "action": "copy_to_clipboard",
    "args": { "text": "{query}" }
  },
  {
    "id": "notify",
    "name": "🔔 发送桌面通知",
    "description": "弹出桌面通知，内容为搜索框文字",
    "icon": "🔔",
    "keywords": ["notify", "通知"],
    "priority": 80,
    "action": "notify",
    "args": { "title": "AlfredPy", "message": "{query}" }
  },
  {
    "id": "hello",
    "name": "🎉 打印问候",
    "description": "打印 Hello World 到终端",
    "icon": "🎉",
    "priority": 100,
    "action": "print",
    "args": { "text": "Hello from AlfredPy! 🚀" }
  }
]
